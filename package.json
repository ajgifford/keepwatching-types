{
  "name": "@ajgifford/keepwatching-types",
  "version": "0.11.5",
  "description": "Shared TypeScript types for KeepWatching application",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepare": "yarn build",
    "clean": "rimraf dist",
    "rebuild": "yarn clean && yarn build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --config ./.prettierrc.cjs . --write",
    "format:check": "prettier --config ./.prettierrc.cjs . --check",
    "type-check": "tsc --noEmit",
    "version:patch": "yarn version --patch",
    "version:minor": "yarn version --minor",
    "version:major": "yarn version --major"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajgifford/keepwatching-types.git"
  },
  "author": "Andy Gifford <ajgifford@users.noreply.github.com>",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsdown": "^0.21.7",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0"
  },
  "resolutions": {
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "flatted": "3.4.2",
    "lodash-es": "4.18.1",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4"
  },
  "packageManager": "yarn@1.22.22"
}
